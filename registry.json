{
  "$schema": "https://ui.shadcn.com/schema/registry.json",
  "name": "dottoui",
  "homepage": "https://yamustofa.github.io/dotto-ui",
  "items": [
    {
      "name": "dotto-core",
      "type": "registry:style",
      "title": "DottoUI Core",
      "description": "DottoUI Tailwind v4 theme tokens, CSS variables, and pixel utilities.",
      "dependencies": [
        "@fontsource/silkscreen",
        "@fontsource/space-mono"
      ],
      "css": {
        "@import \"./styles/_dotto-core.css\"": {}
      },
      "files": [
        {
          "path": "src/styles/_dotto-core.css",
          "type": "registry:style",
          "target": "src/styles/_dotto-core.css"
        }
      ]
    },
    {
      "name": "utils",
      "type": "registry:lib",
      "title": "cn utility",
      "description": "Class name utility used by DottoUI components.",
      "dependencies": [
        "clsx",
        "tailwind-merge"
      ],
      "files": [
        {
          "path": "src/lib/utils.ts",
          "type": "registry:lib",
          "target": "@lib/utils.ts"
        }
      ]
    },
    {
      "name": "dotto",
      "type": "registry:item",
      "title": "DottoUI",
      "description": "Install the DottoUI core, utilities, and all current components.",
      "registryDependencies": [
        "https://yamustofa.github.io/dotto-ui/r/button.json",
        "https://yamustofa.github.io/dotto-ui/r/badge.json",
        "https://yamustofa.github.io/dotto-ui/r/card.json",
        "https://yamustofa.github.io/dotto-ui/r/input.json",
        "https://yamustofa.github.io/dotto-ui/r/label.json",
        "https://yamustofa.github.io/dotto-ui/r/textarea.json",
        "https://yamustofa.github.io/dotto-ui/r/checkbox.json",
        "https://yamustofa.github.io/dotto-ui/r/pixel-glyph.json",
        "https://yamustofa.github.io/dotto-ui/r/icon-tile.json",
        "https://yamustofa.github.io/dotto-ui/r/sticky-note.json"
      ]
    },
    {
      "name": "button",
      "type": "registry:ui",
      "title": "Button",
      "description": "A shadcn-style button with DottoUI pixel corners, depth, and hard press motion.",
      "dependencies": [
        "@radix-ui/react-slot",
        "class-variance-authority"
      ],
      "registryDependencies": [
        "https://yamustofa.github.io/dotto-ui/r/dotto-core.json",
        "https://yamustofa.github.io/dotto-ui/r/utils.json"
      ],
      "files": [
        {
          "path": "src/components/ui/button.tsx",
          "type": "registry:ui",
          "target": "@ui/button.tsx"
        }
      ]
    },
    {
      "name": "badge",
      "type": "registry:ui",
      "title": "Badge",
      "description": "A compact shadcn-style badge for metadata, status, and tags.",
      "dependencies": [
        "class-variance-authority"
      ],
      "registryDependencies": [
        "https://yamustofa.github.io/dotto-ui/r/dotto-core.json",
        "https://yamustofa.github.io/dotto-ui/r/utils.json"
      ],
      "files": [
        {
          "path": "src/components/ui/badge.tsx",
          "type": "registry:ui",
          "target": "@ui/badge.tsx"
        }
      ]
    },
    {
      "name": "card",
      "type": "registry:ui",
      "title": "Card",
      "description": "A shadcn-compatible card anatomy with DottoUI pixel borders and depth.",
      "registryDependencies": [
        "https://yamustofa.github.io/dotto-ui/r/dotto-core.json",
