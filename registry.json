{
  "$schema": "https://ui.shadcn.com/schema/registry.json",
  "name": "dottoui",
  "homepage": "https://yamustofa.github.io/dotto-ui",
  "items": [
    {
      "name": "dotto-core",
      "type": "registry:style",
      "title": "DottoUI Core",
      "description": "DottoUI Tailwind v4 theme tokens, CSS variables, and pixel utilities.",
      "files": [
        {
          "path": "src/styles/_dotto-core.css",
          "type": "registry:style",
          "target": "src/styles/_dotto-core.css"
        }
      ]
    },
    {
      "name": "utils",
      "type": "registry:lib",
      "title": "cn utility",
      "description": "Class name utility used by DottoUI components.",
      "dependencies": ["clsx", "tailwind-merge"],
      "files": [
        {
          "path": "src/lib/utils.ts",
          "type": "registry:lib",
          "target": "@lib/utils.ts"
        }
      ]
    },
    {
      "name": "button",
      "type": "registry:ui",
      "title": "Button",
      "description": "A shadcn-style button with DottoUI pixel corners, depth, and hard press motion.",
      "dependencies": ["@radix-ui/react-slot", "class-variance-authority"],
      "registryDependencies": ["dotto-core", "utils"],
      "files": [
        {
          "path": "src/components/ui/button.tsx",
          "type": "registry:ui",
          "target": "@ui/button.tsx"
        }
      ]
    },
    {
      "name": "badge",
      "type": "registry:ui",
      "title": "Badge",
      "description": "A compact shadcn-style badge for metadata, status, and tags.",
      "dependencies": ["class-variance-authority"],
      "registryDependencies": ["dotto-core", "utils"],
      "files": [
        {
          "path": "src/components/ui/badge.tsx",
          "type": "registry:ui",
          "target": "@ui/badge.tsx"
        }
      ]
    },
    {
      "name": "card",
      "type": "registry:ui",
      "title": "Card",
      "description": "A shadcn-compatible card anatomy with DottoUI pixel borders and depth.",
      "registryDependencies": ["dotto-core", "utils"],
      "files": [
        {
          "path": "src/components/ui/card.tsx",
          "type": "registry:ui",
          "target": "@ui/card.tsx"
        }
      ]
    },
    {
      "name": "input",
      "type": "registry:ui",
      "title": "Input",
      "description": "A native input styled with DottoUI pixel borders and mono labels.",
      "registryDependencies": ["dotto-core", "utils"],
      "files": [
        {
          "path": "src/components/ui/input.tsx",
          "type": "registry:ui",
          "target": "@ui/input.tsx"
        }
      ]
    },
    {
      "name": "label",
      "type": "registry:ui",
      "title": "Label",
      "description": "An uppercase mono label for DottoUI forms.",
      "registryDependencies": ["dotto-core", "utils"],
      "files": [
        {
          "path": "src/components/ui/label.tsx",
          "type": "registry:ui",
          "target": "@ui/label.tsx"
        }
      ]
    },
    {
      "name": "textarea",
      "type": "registry:ui",
      "title": "Textarea",
      "description": "A native textarea styled with DottoUI pixel borders.",
      "registryDependencies": ["dotto-core", "utils"],
      "files": [
        {
          "path": "src/components/ui/textarea.tsx",
          "type": "registry:ui",
          "target": "@ui/textarea.tsx"
        }
      ]
    },
    {
      "name": "checkbox",
      "type": "registry:ui",
      "title": "Checkbox",
      "description": "A Radix checkbox with DottoUI pixel depth and icon styling.",
      "dependencies": ["@radix-ui/react-checkbox", "pixelarticons"],
      "registryDependencies": ["dotto-core", "utils"],
      "files": [
        {
          "path": "src/components/ui/checkbox.tsx",
          "type": "registry:ui",
          "target": "@ui/checkbox.tsx"
        }
      ]
    },
    {
      "name": "pixel-glyph",
      "type": "registry:component",
      "title": "PixelGlyph",
      "description": "A tiny pixel motif component drawn with square box shadows.",
      "registryDependencies": ["dotto-core"],
      "files": [
        {
          "path": "src/components/dotto/pixel-glyph.tsx",
          "type": "registry:component",
          "target": "@components/dotto/pixel-glyph.tsx"
        }
      ]
    },
    {
      "name": "icon-tile",
      "type": "registry:component",
      "title": "IconTile",
      "description": "A DottoUI icon container with pixel corners.",
      "registryDependencies": ["dotto-core", "utils"],
      "files": [
        {
          "path": "src/components/dotto/icon-tile.tsx",
          "type": "registry:component",
          "target": "@components/dotto/icon-tile.tsx"
        }
      ]
    },
    {
      "name": "sticky-note",
      "type": "registry:component",
      "title": "StickyNote",
      "description": "A small pixel-bordered note component for crafted callouts.",
      "registryDependencies": ["dotto-core", "utils"],
      "files": [
        {
          "path": "src/components/dotto/sticky-note.tsx",
          "type": "registry:component",
          "target": "@components/dotto/sticky-note.tsx"
        }
      ]
    }
  ]
}
